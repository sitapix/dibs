{
  "default": true,
  "MD013": {
    "line_length": 85,
    "heading_line_length": 85,
    "code_blocks": false,
    "tables": false,
    "stern": true
  },
  "MD033": false,
  "MD041": false,
  "MD060": false,
  "ignores": [
    ".github/**",
    "vendor/**",
    "node_modules/**",
    "release-notes.md"
  ]
}
